<div class="grid">
<% for (const item of items) {
  const repo = 'https://github.com/hackods/' + item.url.replace('https://hackods.github.io/', '').replace(/\/$/, '');
%>
<div class="g-col-12 g-col-sm-6 g-col-md-4 g-col-lg-3">
<a class="tablero-thumb" href="<%- item.url %>" target="_blank"><img src="<%- item.imagen %>" alt="<%- item.equipo %>" loading="lazy"></a>
<strong class="tablero-name"><%- item.equipo %></strong>
<% if (item.integrantes) { %><span class="integrantes"><%- item.integrantes %></span><% } %>
<a class="repo-link" href="<%- repo %>" target="_blank" rel="noopener"><i class="bi bi-github"></i> repositorio</a>
</div>
<% } %>
</div>
